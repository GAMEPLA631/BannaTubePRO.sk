{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to user's profile picture" },
        "bio": { "type": "string", "description": "User's biography" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created" }
      },
      "required": ["displayName", "email", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "description": "Video metadata and content URLs",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Video title" },
        "description": { "type": "string", "description": "Video description" },
        "videoUrl": { "type": "string", "format": "uri", "description": "URL to the video file" },
        "thumbnailUrl": { "type": "string", "format": "uri", "description": "URL to the video thumbnail" },
        "authorId": { "type": "string", "description": "UID of the uploader" },
        "authorName": { "type": "string", "description": "Name of the uploader (denormalized)" },
        "authorPhoto": { "type": "string", "description": "Photo of the uploader (denormalized)" },
        "views": { "type": "number", "description": "Number of views" },
        "likes": { "type": "number", "description": "Number of likes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the video was uploaded" }
      },
      "required": ["title", "videoUrl", "authorId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a video",
      "type": "object",
      "properties": {
        "videoId": { "type": "string", "description": "ID of the video" },
        "authorId": { "type": "string", "description": "UID of the commenter" },
        "authorName": { "type": "string", "description": "Name of the commenter" },
        "authorPhoto": { "type": "string", "description": "Photo of the commenter" },
        "text": { "type": "string", "description": "Comment text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the comment was posted" }
      },
      "required": ["videoId", "authorId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profile data"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Stores video metadata"
    },
    "/videos/{videoId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Stores comments for a specific video"
    }
  }
}
